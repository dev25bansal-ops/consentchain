    {
      "name": "Consent Management",
      "item": [
        {
          "name": "Create Consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"principal_wallet\": \"{{principal_wallet}}\",\n  \"fiduciary_id\": \"{{fiduciary_id}}\",\n  \"purpose\": \"identity_verification\",\n  \"data_types\": [\"identity\", \"contact\"],\n  \"duration_days\": 365,\n  \"signature\": \"<wallet_signature>\",\n  \"metadata\": {\"source\": \"postman\"}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/consent/create",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "create"]
            }
          }
        },
        {
          "name": "Batch Create Consents",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"batch_id\": \"batch_001\",\n  \"consents\": [\n    {\n      \"principal_wallet\": \"{{principal_wallet}}\",\n      \"fiduciary_id\": \"{{fiduciary_id}}\",\n      \"purpose\": \"identity_verification\",\n      \"data_types\": [\"identity\"],\n      \"duration_days\": 90,\n      \"signature\": \"<signature>\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/consent/batch",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "batch"]
            }
          }
        },
        {
          "name": "Revoke Consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consent_id\": \"{{consent_id}}\",\n  \"reason\": \"User requested revocation\",\n  \"signature\": \"<wallet_signature>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/consent/revoke",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "revoke"]
            }
          }
        },
        {
          "name": "Modify Consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consent_id\": \"{{consent_id}}\",\n  \"new_purpose\": \"healthcare_services\",\n  \"new_data_types\": [\"health\", \"identity\"],\n  \"new_duration_days\": 180,\n  \"reason\": \"Purpose expansion\",\n  \"signature\": \"<signature>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/consent/modify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "modify"]
            }
          }
        },
        {
          "name": "Verify Consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consent_id\": \"{{consent_id}}\",\n  \"principal_id\": \"{{principal_wallet}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/consent/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "verify"]
            }
          }
        },
        {
          "name": "Query Consents",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/consent/query?status=GRANTED&page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "query"],
              "query": [
                { "key": "status", "value": "GRANTED" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "purpose", "value": "" },
                { "key": "principal_id", "value": "" },
                { "key": "from_date", "value": "" },
                { "key": "to_date", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Consent by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/consent/{{consent_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "{{consent_id}}"]
            }
          }
        },
        {
          "name": "Get Consent History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/consent/{{consent_id}}/history",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "{{consent_id}}", "history"]
            }
          }
        },
        {
          "name": "Get Expiring Consents",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/consent/expiring?days=30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "expiring"],
              "query": [{ "key": "days", "value": "30" }]
            }
          }
        },
        {
          "name": "Renew Consent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"duration_days\": 365,\n  \"signature\": \"<signature>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/consent/{{consent_id}}/renew",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "consent", "{{consent_id}}", "renew"]
            }
          }
        }
      ]
    },
    {
      "name": "Audit & Compliance",
      "item": [
        {
          "name": "Query Audit Logs",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page\": 1,\n  \"limit\": 20\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/audit/query",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "audit", "query"]
            }
          }
        },
        {
          "name": "Generate Merkle Root",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\"event_id_1\", \"event_id_2\"]"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/audit/merkle-root",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "audit", "merkle-root"]
            }
          }
        },
        {
          "name": "Generate Compliance Report",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-API-Key", "value": "{{api_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fiduciary_id\": \"{{fiduciary_id}}\",\n  \"period_start\": \"2024-01-01T00:00:00Z\",\n  \"period_end\": \"2024-12-31T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/compliance/report",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "compliance", "report"]
            }
          }
        },
        {
          "name": "Get Compliance Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/compliance/status/{{fiduciary_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "compliance", "status", "{{fiduciary_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Grievance Management",
      "item": [
        {
          "name": "Submit Grievance",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"principal_id\": \"<principal_uuid>\",\n  \"fiduciary_id\": \"{{fiduciary_id}}\",\n  \"grievance_type\": \"unauthorized_access\",\n  \"subject\": \"Data accessed without consent\",\n  \"description\": \"My personal data was accessed by the fiduciary without proper consent verification. This violates DPDP Act provisions.\",\n  \"consent_id\": \"{{consent_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/grievance/submit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "grievance", "submit"]
            }
          }
        },
        {
          "name": "Acknowledge Grievance",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/grievance/{{grievance_id}}/acknowledge",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "grievance", "{{grievance_id}}", "acknowledge"]
            }
          }
        },
        {
          "name": "Resolve Grievance",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/grievance/{{grievance_id}}/resolve?resolution=Investigation complete. No unauthorized access found.",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "grievance", "{{grievance_id}}", "resolve"],
              "query": [
                { "key": "resolution", "value": "Investigation complete. No unauthorized access found." }
              ]
            }
          }
        },
        {
          "name": "List Grievances",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/grievance/list?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "grievance", "list"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        },
        {
          "name": "Check SLA Compliance",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/grievance/sla/{{fiduciary_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "grievance", "sla", "{{fiduciary_id}}"]
            }
          }
        }
      ]
    },
