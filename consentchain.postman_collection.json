          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/guardian/check?guardian_wallet=<wallet>&principal_id=<uuid>&action=data_access",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "guardian", "check"],
