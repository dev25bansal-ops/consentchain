      "item": [
        {
          "name": "Register Fiduciary",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Fiduciary Corp\",\n  \"registration_number\": \"TFC-2024-001\",\n  \"contact_email\": \"contact@testfiduciary.com\",\n  \"data_categories\": [\"identity\", \"financial\"],\n  \"purposes\": [\"identity_verification\", \"credit_assessment\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/fiduciary/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "fiduciary", "register"]
