              "raw": "{\n  \"principal_id\": \"<principal_uuid>\",\n  \"guardian_wallet\": \"<guardian_wallet_address>\",\n  \"guardian_name\": \"John Doe\",\n  \"relationship\": \"parent\",\n  \"relationship_proof_hash\": \"<hash>\",\n  \"signature\": \"<signature>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/guardian/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "guardian", "register"]
