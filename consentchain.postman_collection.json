    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login with Wallet",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login?wallet_address={{principal_wallet}}&signature=<signature>&message=<message>",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"],
              "query": [
                { "key": "wallet_address", "value": "{{principal_wallet}}" },
                { "key": "signature", "value": "<signature>" },
                { "key": "message", "value": "<message>" }
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"<your_refresh_token>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout (Revoke Token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<your_token>\",\n  \"reason\": \"logout\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "OAuth2/OIDC",
      "item": [
        {
          "name": "OAuth2 Login - Google",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/oauth/login/google?redirect_uri=http://localhost:3000/callback",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "oauth", "login", "google"],
              "query": [
                { "key": "redirect_uri", "value": "http://localhost:3000/callback" }
              ]
            }
          }
        },
        {
          "name": "OAuth2 Callback",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/oauth/callback?code=<auth_code>&state=<state>",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "oauth", "callback"],
              "query": [
                { "key": "code", "value": "<auth_code>" },
                { "key": "state", "value": "<state>" }
              ]
            }
          }
        },
        {
          "name": "Link OAuth Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"google\",\n  \"code\": \"<auth_code>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/oauth/link",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "oauth", "link"]
            }
          }
        },
        {
          "name": "Unlink OAuth Account",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/oauth/unlink/google",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "oauth", "unlink", "google"]
            }
          }
        }
      ]
    },
    {
