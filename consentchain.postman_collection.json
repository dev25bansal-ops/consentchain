    {
      "name": "Data Deletion",
      "item": [
        {
          "name": "Create Deletion Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"principal_id\": \"<principal_uuid>\",\n  \"fiduciary_id\": \"{{fiduciary_id}}\",\n  \"scope\": \"all\",\n  \"reason\": \"Right to erasure under DPDP Act\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/deletion/request",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deletion", "request"]
            }
          }
        },
        {
          "name": "Execute Deletion",
          "request": {
            "method": "POST",
            "header": [{ "key": "X-API-Key", "value": "{{api_key}}" }],
            "url": {
              "raw": "{{base_url}}/api/v1/deletion/{{request_id}}/execute",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deletion", "{{request_id}}", "execute"]
            }
          }
        },
        {
          "name": "Get Deletion Certificate",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/deletion/{{request_id}}/certificate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "deletion", "{{request_id}}", "certificate"]
            }
          }
        }
      ]
