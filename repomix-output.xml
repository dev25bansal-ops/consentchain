                v-model="filterPurpose"
                class="border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-500"
              >
                <option value="">All Purposes</option>
                <option value="MARKETING">Marketing</option>
                <option value="ANALYTICS">Analytics</option>
                <option value="SERVICE_DELIVERY">Service Delivery</option>
                <option value="THIRD_PARTY_SHARING">Third Party</option>
              </select>
            </div>
          </div>

          <div v-if="loading" class="text-center py-8">
            <div
              class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600 mx-auto"
            ></div>
            <p class="mt-4 text-gray-600">Loading your consents...</p>
          </div>

          <div
            v-else-if="filteredConsents.length === 0"
            class="bg-white rounded-xl shadow p-8 text-center"
          >
            <svg
              class="mx-auto h-12 w-12 text-gray-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              />
            </svg>
            <p class="mt-4 text-gray-600">
              No consents found matching your criteria.
            </p>
          </div>

          <div v-else class="space-y-4">
            <div
              v-for="consent in filteredConsents"
              :key="consent.consent_id"
              class="bg-white rounded-xl shadow hover:shadow-lg transition p-6"
            >
              <div class="flex justify-between items-start">
                <div class="flex-1">
                  <div class="flex items-center space-x-3">
                    <span
                      :class="{
                                            'bg-green-100 text-green-800': consent.status === 'GRANTED',
                                            'bg-red-100 text-red-800': consent.status === 'REVOKED',
                                            'bg-yellow-100 text-yellow-800': consent.status === 'EXPIRED',
                                            'bg-gray-100 text-gray-800': consent.status === 'MODIFIED',
                                        }"
                      class="px-3 py-1 rounded-full text-sm font-medium"
                    >
                      {{ consent.status }}
                    </span>
                    <span class="text-sm text-gray-500">
                      {{ consent.purpose }}
                    </span>
                  </div>
                  <h3 class="mt-2 text-lg font-semibold text-gray-900">
                    {{ consent.fiduciary_name || 'Data Fiduciary' }}
                  </h3>
                  <p class="mt-1 text-sm text-gray-600">
                    Data Types: {{ consent.data_types.join(', ') }}
                  </p>
                  <div
                    class="mt-2 flex items-center space-x-4 text-sm text-gray-500"
                  >
                    <span>Granted: {{ formatDate(consent.granted_at) }}</span>
                    <span v-if="consent.expires_at">
                      Expires: {{ formatDate(consent.expires_at) }}
                    </span>
                  </div>
                  <div class="mt-2 text-xs text-gray-400 font-mono truncate">
                    TX: {{ consent.on_chain_tx_id }}
                  </div>
                </div>
                <div class="flex flex-col space-y-2 ml-4">
                  <button
                    v-if="consent.status === 'GRANTED'"
                    @click="openRevokeModal(consent)"
                    class="bg-red-50 text-red-600 px-4 py-2 rounded-lg font-medium hover:bg-red-100 transition"
                  >
                    Revoke
                  </button>
                  <button
                    @click="viewConsentHistory(consent)"
                    class="bg-gray-50 text-gray-600 px-4 py-2 rounded-lg font-medium hover:bg-gray-100 transition"
                  >
                    View History
                  </button>
                  <button
                    @click="verifyConsent(consent)"
                    class="bg-indigo-50 text-indigo-600 px-4 py-2 rounded-lg font-medium hover:bg-indigo-100 transition"
                  >
                    Verify on Chain
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>

      <div
        v-if="showRevokeModal"
        class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50"
      >
        <div class="bg-white rounded-xl shadow-xl max-w-md w-full mx-4 p-6">
          <h3 class="text-xl font-bold text-gray-900 mb-4">Revoke Consent</h3>
          <p class="text-gray-600 mb-4">
            Are you sure you want to revoke this consent? This action will be
            recorded on the blockchain and the data fiduciary will be notified.
          </p>
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-2"
              >Reason (optional)</label
            >
            <textarea
              v-model="revokeReason"
              class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-indigo-500"
              rows="3"
              placeholder="Enter reason for revocation..."
            ></textarea>
          </div>
          <div class="flex justify-end space-x-4">
            <button
              @click="showRevokeModal = false"
              class="px-4 py-2 text-gray-600 hover:text-gray-800"
            >
              Cancel
            </button>
            <button
              @click="confirmRevoke"
              :disabled="revoking"
              class="bg-red-600 text-white px-6 py-2 rounded-lg font-medium hover:bg-red-700 disabled:opacity-50"
            >
              {{ revoking ? 'Revoking...' : 'Confirm Revoke' }}
            </button>
          </div>
        </div>
      </div>

      <div
        v-if="showHistoryModal"
        class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50"
      >
        <div
          class="bg-white rounded-xl shadow-xl max-w-2xl w-full mx-4 p-6 max-h-[80vh] overflow-y-auto"
        >
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold text-gray-900">Consent History</h3>
            <button
              @click="showHistoryModal = false"
              class="text-gray-400 hover:text-gray-600"
            >
              <svg
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            </button>
          </div>
          <div class="space-y-4">
            <div
              v-for="event in consentHistory"
              :key="event.event_id"
              class="border-l-4 pl-4 py-2"
              :class="{
                            'border-green-500': event.event_type === 'CONSENT_GRANTED',
                            'border-red-500': event.event_type === 'CONSENT_REVOKED',
                            'border-yellow-500': event.event_type === 'CONSENT_MODIFIED',
                        }"
            >
              <div class="flex justify-between">
                <span class="font-medium">{{ event.event_type }}</span>
                <span class="text-sm text-gray-500"
                  >{{ formatDate(event.created_at) }}</span
                >
              </div>
              <p class="text-sm text-gray-600 mt-1">
                Status: {{ event.previous_status || 'N/A' }} → {{
                event.new_status }}
              </p>
              <p class="text-xs text-gray-400 mt-1 font-mono">
                TX: {{ event.tx_id }}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const { createApp, ref, computed, onMounted } = Vue;

      createApp({
        setup() {
          const API_BASE = "http://localhost:8000/api/v1";

          const principalId = ref(null);
          const consents = ref([]);
          const loading = ref(false);
          const filterStatus = ref("");
          const filterPurpose = ref("");

          const stats = ref({
            activeConsents: 0,
            revokedConsents: 0,
            expiringSoon: 0,
            fiduciaries: 0,
          });

          const showRevokeModal = ref(false);
          const selectedConsent = ref(null);
          const revokeReason = ref("");
          const revoking = ref(false);

          const showHistoryModal = ref(false);
          const consentHistory = ref([]);

          const filteredConsents = computed(() => {
            return consents.value.filter((c) => {
              if (filterStatus.value && c.status !== filterStatus.value)
                return false;
              if (filterPurpose.value && c.purpose !== filterPurpose.value)
                return false;
              return true;
            });
          });

          const connectWallet = async () => {
            try {
              if (typeof window.algorand !== "undefined") {
                const accounts = await window.algorand.enable();
                principalId.value = accounts[0];
                await loadConsents();
              } else {
                alert(
                  "Please install an Algorand wallet (Pera, Defly, or Exodus)",
                );
              }
            } catch (error) {
              console.error("Wallet connection error:", error);
              principalId.value = "TEST_WALLET_ADDRESS";
              await loadConsents();
            }
          };

          const disconnectWallet = () => {
            principalId.value = null;
            consents.value = [];
            stats.value = {
              activeConsents: 0,
              revokedConsents: 0,
              expiringSoon: 0,
              fiduciaries: 0,
            };
          };

          const loadConsents = async () => {
            loading.value = true;
            try {
              const response = await axios.get(`${API_BASE}/consent/query`, {
                params: { principal_id: principalId.value },
              });
              consents.value = response.data.data.consents;

              stats.value = {
                activeConsents: consents.value.filter(
                  (c) => c.status === "GRANTED",
                ).length,
                revokedConsents: consents.value.filter(
                  (c) => c.status === "REVOKED",
                ).length,
                expiringSoon: consents.value.filter((c) => {
                  if (!c.expires_at) return false;
                  const expiry = new Date(c.expires_at);
                  const weekFromNow = new Date();
                  weekFromNow.setDate(weekFromNow.getDate() + 7);
                  return expiry < weekFromNow && c.status === "GRANTED";
                }).length,
                fiduciaries: [
                  ...new Set(consents.value.map((c) => c.fiduciary_id)),
                ].length,
              };
            } catch (error) {
              console.error("Error loading consents:", error);
              consents.value = [];
            } finally {
              loading.value = false;
            }
          };

          const openRevokeModal = (consent) => {
            selectedConsent.value = consent;
            revokeReason.value = "";
            showRevokeModal.value = true;
          };

          const confirmRevoke = async () => {
            revoking.value = true;
            try {
              await axios.post(`${API_BASE}/consent/revoke`, {
                consent_id: selectedConsent.value.consent_id,
                reason: revokeReason.value,
                signature: "PLACEHOLDER",
              });
              showRevokeModal.value = false;
              await loadConsents();
            } catch (error) {
              console.error("Revoke error:", error);
              alert("Failed to revoke consent. Please try again.");
            } finally {
              revoking.value = false;
            }
          };

          const viewConsentHistory = async (consent) => {
            try {
              const response = await axios.get(
                `${API_BASE}/consent/${consent.consent_id}/history`,
              );
              consentHistory.value = response.data.data.events;
              showHistoryModal.value = true;
            } catch (error) {
              console.error("History error:", error);
            }
          };

          const verifyConsent = async (consent) => {
            try {
              const response = await axios.post(`${API_BASE}/consent/verify`, {
                consent_id: consent.consent_id,
              });
              if (response.data.success) {
                alert("Consent is valid and verified on-chain!");
              } else {
                alert(`Consent verification: ${response.data.message}`);
              }
            } catch (error) {
              console.error("Verify error:", error);
            }
          };

          const formatDate = (dateStr) => {
            if (!dateStr) return "N/A";
            return new Date(dateStr).toLocaleDateString("en-IN", {
              year: "numeric",
              month: "short",
              day: "numeric",
            });
          };

          return {
            principalId,
            consents,
            loading,
            filterStatus,
            filterPurpose,
            filteredConsents,
            stats,
            showRevokeModal,
            selectedConsent,
            revokeReason,
            revoking,
            showHistoryModal,
            consentHistory,
            connectWallet,
            disconnectWallet,
            openRevokeModal,
            confirmRevoke,
            viewConsentHistory,
            verifyConsent,
            formatDate,
          };
        },
      }).mount("#app");
    </script>
  </body>
</html>
</file>

